# DSPatch Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# =============================================================================
# IBM watsonx.ai
# =============================================================================
WATSONX_API_KEY=your_watsonx_api_key_here
WATSONX_PROJECT_ID=your_watsonx_project_id_here
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_MODEL_ID=ibm/granite-13b-chat-v2
EMBEDDING_MODEL=ibm/slate-125m-english-rtrvr

# =============================================================================
# Google Gemini
# =============================================================================
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash-live

# =============================================================================
# Twilio
# =============================================================================
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# =============================================================================
# Database (PostgreSQL + pgvector)
# =============================================================================
DATABASE_URL=postgresql://dspatch:password@localhost:5432/dspatch
POSTGRES_USER=dspatch
POSTGRES_PASSWORD=password
POSTGRES_DB=dspatch

# =============================================================================
# Server
# =============================================================================
WEBSOCKET_URL=wss://your-server-url.com/ws
FLASK_ENV=development
FLASK_PORT=5000
REACT_APP_API_URL=http://localhost:5000
