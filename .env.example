# DSPatch Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# =============================================================================
# Feature flags — set these to run locally without any real credentials
# =============================================================================
WATSONX_ENABLED=false
GEMINI_ENABLED=false
TWILIO_VALIDATE_SIGNATURES=false
DEMO_BUSINESS_ID=detroit-plumbing-co

# =============================================================================
# IBM watsonx.ai
# =============================================================================
WATSONX_API_KEY=your_watsonx_api_key_here
WATSONX_PROJECT_ID=your_watsonx_project_id_here
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_MODEL_ID=meta-llama/llama-3-3-70b-instruct
EMBEDDING_MODEL=ibm/slate-125m-english-rtrvr

# =============================================================================
# Google Gemini
# =============================================================================
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash-live

# =============================================================================
# Twilio
# =============================================================================
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# =============================================================================
# IBM Cloudant (production database — replaces Postgres when both vars are set)
# =============================================================================
CLOUDANT_URL=https://your-instance.cloudantnosqldb.appdomain.cloud
CLOUDANT_APIKEY=your_cloudant_apikey_here

# =============================================================================
# Database (PostgreSQL + pgvector — local dev only)
# =============================================================================
DATABASE_URL=postgresql://dspatch:password@localhost:5432/dspatch
POSTGRES_USER=dspatch
POSTGRES_PASSWORD=password
POSTGRES_DB=dspatch

# =============================================================================
# Server
# =============================================================================
JWT_SECRET=replace_with_at_least_32_random_characters
FRONTEND_ORIGIN=http://localhost:3000
FLASK_PUBLIC_URL=https://your-code-engine-url.codeengine.appdomain.cloud
WEBSOCKET_URL=wss://your-server-url.com/ws
WEBSOCKET_PORT=8765
FLASK_ENV=development
FLASK_PORT=5000
REACT_APP_API_URL=http://localhost:5000
